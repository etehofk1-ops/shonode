# Copy this file to `.env` and fill in your Gemini key.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
PORT=4173
# Optional: comma-separated web origins allowed to call /api/storyboard
# SHONODE_ALLOWED_ORIGINS=https://shonode.vercel.app,https://your-domain.com
# Optional: lock the security scanner behind a token on deployed environments
# SHONODE_SECURITY_SCAN_TOKEN=choose-a-long-random-token
# Optional: only set this in trusted internal environments if you need deployed scans for private URLs
# SHONODE_ALLOW_PRIVATE_SECURITY_SCAN=1

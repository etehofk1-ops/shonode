# Copy this file to `.env` and fill in your Gemini key.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
PORT=4173

# Optional: bind only to loopback by default. Use 0.0.0.0 only on trusted networks.
# SHONODE_HOST=127.0.0.1

# Optional: enable the hosted/serverless AI proxy explicitly.
# Keep false/unset for public demo deployments unless you add abuse protection.
# SHONODE_ENABLE_HOSTED_AI_PROXY=true

# Optional: comma-separated web origins allowed to call /api/storyboard.
# SHONODE_ALLOWED_ORIGINS=https://shonode.vercel.app,https://your-domain.com

# Optional: per-IP AI proxy rate limit.
# SHONODE_RATE_LIMIT_PER_MINUTE=20

# Optional: comma-separated Gemini model allowlist.
# SHONODE_ALLOWED_GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Optional: only trust X-Forwarded-For when behind a trusted reverse proxy.
# SHONODE_TRUST_PROXY=false

# Optional: expose the passive security scanner (a remote URL fetcher) on hosted
# deployments. Disabled by default; keep it off for public demos.
# SHONODE_ENABLE_HOSTED_SECURITY_SCAN=true
# Optional: lock the security scanner behind a token on deployed environments.
# SHONODE_SECURITY_SCAN_TOKEN=choose-a-long-random-token
# Optional: only set this in trusted internal environments if you need deployed scans for private URLs.
# SHONODE_ALLOW_PRIVATE_SECURITY_SCAN=1

# Copy this file to `.env` and fill in your Gemini key.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
PORT=4173
# Optional: enable the hosted/serverless AI proxy explicitly.
# Keep false/unset for public demo deployments unless you add abuse protection.
# SHONODE_ENABLE_HOSTED_AI_PROXY=true
# Optional: comma-separated web origins allowed to call /api/storyboard
# SHONODE_ALLOWED_ORIGINS=https://shonode.vercel.app,https://your-domain.com
